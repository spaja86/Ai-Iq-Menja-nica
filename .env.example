# Application
ENVIRONMENT=development
APP_NAME="Ai IQ Menjačnica"
LOG_LEVEL=debug

# Domain
PUBLIC_BASE_URL=http://localhost:7777
DOMAIN=localhost

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spaja
DB_USER=spaja
DB_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://spaja:change_me@localhost:5432/spaja

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379/0

# Security
JWT_SECRET_KEY=dev_secret_key_change_in_production
ED25519_SEED_B64=your_base64_encoded_ed25519_seed
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=14

# Stripe (use test keys)
STRIPE_API_KEY=sk_test_your_stripe_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_test_webhook_secret

# PayPal (use sandbox)
PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_ENV=sandbox

# Email
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@localhost

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090

# CORS
CORS_ORIGINS=*

# Admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin123
