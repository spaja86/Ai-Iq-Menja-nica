# App Configuration
APP_NAME="Ai IQ Menjačnica"
APP_VERSION="1.0.0"
DEBUG=false

# Security
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY
ED25519_SEED_B64=CHANGE_ME_TO_BASE64_ENCODED_32_BYTE_SEED

# Database (Choose one)
# SQLite (Development)
DATABASE_URL=sqlite:///./exchange.db

# PostgreSQL (Production)
# POSTGRES_SERVER=localhost
# POSTGRES_USER=exchange
# POSTGRES_PASSWORD=changeme123
# POSTGRES_DB=aiiq_exchange
# POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=10/minute
REGISTER_RATE_LIMIT=5/minute

# Payment Providers
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# Coinbase Commerce
COINBASE_API_KEY=...
COINBASE_WEBHOOK_SECRET=...

# BitPay
BITPAY_API_TOKEN=...
BITPAY_ENVIRONMENT=test

# Blockchain Nodes
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=changeme
BITCOIN_RPC_HOST=localhost
BITCOIN_RPC_PORT=8332

ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Trading Fees (percentage)
MAKER_FEE_PERCENT=0.1
TAKER_FEE_PERCENT=0.2

# Admin
ADMIN_EMAIL=spajicn@yahoo.com
ADMIN_PASSWORD=ChangeMe123!

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
EMAILS_FROM_EMAIL=noreply@aiiqmenjacnica.com

# Monitoring (Optional)
SENTRY_DSN=https://...@sentry.io/...
